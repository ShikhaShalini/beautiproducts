{{ 'zack-theme.css' | asset_url | stylesheet_tag }}

<section class="zack-section zack-hero" data-section-id="{{ section.id }}">
  <div class="swiper zack-hero__swiper">
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        <div class="swiper-slide zack-hero__slide" {{ block.shopify_attributes }}>
          {% if block.settings.image %}
            {{ block.settings.image | image_url: width: 2200 | image_tag: loading: 'eager', widths: '900, 1400, 1800, 2200', class: 'zack-hero__media', alt: block.settings.headline }}
          {% endif %}
          <div class="zack-hero__overlay"></div>
          <div class="zack-container">
            <div class="zack-hero__copy" data-zack-reveal>
              <p class="zack-eyebrow">{{ block.settings.kicker }}</p>
              <h1 class="zack-hero__brand">{{ block.settings.brand }}</h1>
              <h2 class="zack-hero__headline">{{ block.settings.headline }}</h2>
              <p>{{ block.settings.text }}</p>
              {% if block.settings.button_label != blank %}
                <a href="{{ block.settings.button_link }}" class="zack-button">{{ block.settings.button_label }}</a>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
    <div class="swiper-pagination"></div>
  </div>
</section>

{% schema %}
{
  "name": "Zack hero banner",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "New glow ritual" },
        { "type": "text", "id": "brand", "label": "Brand", "default": "Zack Beauty" },
        { "type": "text", "id": "headline", "label": "Headline", "default": "Premium beauty products for a soft-focus finish." },
        { "type": "textarea", "id": "text", "label": "Text", "default": "High-performance skincare and makeup wrapped in blush, rose gold, and modern luxury." },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
        { "type": "url", "id": "button_link", "label": "Button link" }
      ]
    }
  ],
  "presets": [
    { "name": "Zack hero banner", "blocks": [{ "type": "slide" }, { "type": "slide" }, { "type": "slide" }] }
  ]
}
{% endschema %}