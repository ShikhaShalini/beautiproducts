<section class="zack-section" style="background:#fff;padding:80px 0;" data-section-id="{{ section.id }}">
  <div class="zack-container">
    <div style="text-align:center;max-width:720px;margin:0 auto 48px;" data-zack-reveal>
      <p class="zack-eyebrow">{{ section.settings.kicker }}</p>
      <h2 style="font-size:clamp(42px,6vw,72px);line-height:.95;margin:16px 0;">{{ section.settings.heading }}</h2>
    </div>
    <div style="columns:2 180px;column-gap:16px;">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" style="display:block;break-inside:avoid;margin-bottom:16px;border-radius:24px;overflow:hidden;background:#f8e5e1;" {{ block.shopify_attributes }} data-zack-reveal>
          {% if block.settings.image %}
            {{ block.settings.image | image_url: width: 700 | image_tag: loading: 'lazy', alt: block.settings.label, style: 'width:100%;height:auto;display:block;' }}
          {% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Instagram feed",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Follow us on Instagram" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "@zack.beauty" }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Post",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "label", "label": "Alt label", "default": "Beauty post" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    { "name": "Instagram feed", "blocks": [{ "type": "post" }, { "type": "post" }, { "type": "post" }, { "type": "post" }, { "type": "post" }, { "type": "post" }] }
  ]
}
{% endschema %}