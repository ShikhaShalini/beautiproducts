<footer class="zack-section zack-footer" data-section-id="{{ section.id }}">
  <div class="zack-container zack-grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr));">
    <div>
      <h2 style="font-size:44px;line-height:.9;margin:0;">{{ section.settings.brand }}</h2>
      <p style="color:#dcc9c7;max-width:360px;line-height:1.8;">{{ section.settings.text }}</p>
    </div>
    {% for block in section.blocks %}
      <div {{ block.shopify_attributes }}>
        <h3 class="zack-eyebrow">{{ block.settings.heading }}</h3>
        {% if block.settings.menu != blank %}
          <ul style="list-style:none;padding:0;margin:20px 0 0;display:grid;gap:12px;">
            {% for link in block.settings.menu.links %}
              <li><a href="{{ link.url }}" style="color:#dcc9c7;text-decoration:none;">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    {% endfor %}
    <div>
      <h3 class="zack-eyebrow">Newsletter</h3>
      {% form 'customer' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input type="email" name="contact[email]" placeholder="Email address" style="width:100%;border:1px solid rgba(255,255,255,.18);border-radius:999px;background:rgba(255,255,255,.08);color:#fff;padding:16px 18px;margin-top:20px;">
        <button type="submit" class="zack-button">Join</button>
      {% endform %}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "brand", "label": "Brand", "default": "Zack Beauty" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "A soft luxury cosmetics destination for modern routines and premium feminine design." }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "presets": [
    { "name": "Footer", "blocks": [{ "type": "menu" }, { "type": "menu" }] }
  ]
}
{% endschema %}